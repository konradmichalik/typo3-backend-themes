parameters:
    ignoreErrors:
        -
            message: '#^Only booleans are allowed in an if condition, int given\.$#'
            identifier: if.condNotBoolean
            count: 1
            path: ../../Classes/Backend/Form/ItemsProcFunc/ThemeItemsProcFunc.php

        -
            message: '#^Method KonradMichalik\\Typo3BackendThemes\\Hook\\DataHandlerHook\:\:enforceSingleDefault\(\) has parameter \$fieldArray with no value type specified in iterable type array\.$#'
            identifier: missingType.iterableValue
            count: 1
            path: ../../Classes/Hook/DataHandlerHook.php

        -
            message: '#^Parameter &\$fieldArray by\-ref type of method KonradMichalik\\Typo3BackendThemes\\Hook\\DataHandlerHook\:\:processDatamap_afterDatabaseOperations\(\) expects array\<string, mixed\>, array given\.$#'
            identifier: parameterByRef.type
            count: 1
            path: ../../Classes/Hook/DataHandlerHook.php

        -
            message: '#^Mixed property fetch in a "\$backendUser\-\>\.\.\." can skip important errors\. Make sure the type is known$#'
            identifier: typePerfect.noMixedPropertyFetcher
            count: 2
            path: ../../Classes/Middleware/ThemeChangeNotificationMiddleware.php

        -
            message: '#^Mixed property fetch in a "\$backendUser\-\>\.\.\." can skip important errors\. Make sure the type is known$#'
            identifier: typePerfect.noMixedPropertyFetcher
            count: 1
            path: ../../Classes/Service/ThemeService.php
