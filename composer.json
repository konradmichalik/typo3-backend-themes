{
	"name": "konradmichalik/typo3-backend-themes",
	"description": "TYPO3 extension to configure and select custom backend color themes with primary/secondary colors, dark mode support and live preview.",
	"license": ["GPL-2.0-or-later"],
	"type": "typo3-cms-extension",
	"authors": [
		{
			"name": "Konrad Michalik",
			"email": "hej@konradmichalik.dev"
		}
	],
	"require": {
		"php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
		"typo3/cms-backend": "^14.0",
		"typo3/cms-core": "^14.0"
	},
	"require-dev": {
		"eliashaeussler/version-bumper": "^3.1.1",
		"helhum/typo3-console": "^8.1",
		"phpunit/phpcov": "^11.0 || ^13.0",
		"phpunit/phpunit": "^11.0 || ^12.0 || ^13.0",
		"typo3/cms-base-distribution": "^14.0",
		"typo3/cms-lowlevel": "^14.0"
	},
	"autoload": {
		"psr-4": {
			"KonradMichalik\\Typo3BackendThemes\\": "Classes"
		}
	},
	"config": {
		"allow-plugins": {
			"eliashaeussler/version-bumper": true,
			"ergebnis/composer-normalize": true,
			"helhum/dotenv-connector": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"audit": {
			"abandoned": "ignore"
		},
		"platform": {
			"php": "8.2"
		},
		"sort-packages": true
	},
	"extra": {
		"konradmichalik/php-cs-fixer-preset": {
			"copyright": 2026
		},
		"typo3/cms": {
			"Package": {
				"providesPackages": {}
			},
			"extension-key": "backend_themes",
			"web-dir": "public"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@cgl install"
		],
		"cgl": "@composer -d Tests/CGL --",
		"docs": [
			"@docs:cleanup",
			"@docs:build",
			"@docs:open"
		],
		"docs:build": "docker compose run --rm docs",
		"docs:cleanup": "rm -rf .Build/docs",
		"docs:open": "open .Build/docs/Index.html",
		"test": "@test:coverage --no-coverage",
		"test:coverage": "phpunit -c phpunit.xml"
	}
}
